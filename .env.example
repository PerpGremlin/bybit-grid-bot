# ============================================================
# .env.example — api key template
# purpose: shows what variables are needed in .env
#          copy this file to .env and fill in real values
#          this file is safe to upload to github
#          NEVER put real keys in this file
# author:  perpgremlin-
# date:    march 2026
# ============================================================

# your bybit api key — get this from bybit api management
BYBIT_API_KEY=your_api_key_here

# your bybit api secret — shown once when key is created
BYBIT_API_SECRET=your_api_secret_here

# set to true for testnet, false for live trading
# NEVER run live funds without extensive testnet testing
BYBIT_TESTNET=true

